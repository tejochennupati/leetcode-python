class Solution(object):
    def licenseKeyFormatting(self, s, k):
        res = []
        count = 0

        for c in reversed(s):
            if c == '-':
                continue

            if count == k:
                res.append('-')
                count = 0

            res.append(c.upper())
            count += 1

        return ''.join(reversed(res))
        
